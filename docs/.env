# Traveloop Environment Variables Configuration
# Do not commit this file to version control.

# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://example.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGci...
SUPABASE_SERVICE_ROLE_KEY=eyJhbGci... # (server-side only)

# GeoDB Cities API (City Search)
NEXT_PUBLIC_GEO_DB_API_KEY=xxx...

# Foursquare Places API (Activity Search)
NEXT_PUBLIC_FOURSQUARE_API_KEY=fsq3...

# Yelp Fusion API (Food Search Fallback)
NEXT_PUBLIC_YELP_API_KEY=xxx...

# Unsplash API (Cover Images)
NEXT_PUBLIC_UNSPLASH_ACCESS_KEY=xxx...

# PostHog (Analytics)
NEXT_PUBLIC_POSTHOG_KEY=phc_xxx...

# Gemini API (Phase 3 features - Server side only via Supabase Edge Function)
GEMINI_API_KEY=xxx...
